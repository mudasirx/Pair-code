# Copy to .env and fill in real values. DO NOT commit .env.

# --- shared (used by both bots) ---
MYSMSPORTAL_USERNAME=your_portal_username
MYSMSPORTAL_PASSWORD=your_portal_password
POLL_INTERVAL_SECONDS=30
STARTUP_NOTIFY=true

# --- Telegram bot (bot.py) ---
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_CHAT_ID=123456789

# --- WhatsApp bot (whatsapp_bot.js) ---
# Digits-only phone number for `npm run pair`. Not needed at runtime.
WHATSAPP_PHONE_NUMBER=923001234567
# Optional: where to send alerts. Defaults to the linked account's own JID.
# Examples: 923001234567 (any number)  or  123456789-1234567890@g.us (group)
WHATSAPP_TARGET=
# Base64-encoded zip of auth_info_baileys/. Generate with `npm run export-auth`
# after pairing locally, then set this in Render env.
WHATSAPP_AUTH_BASE64=
