# Copy to .env and fill in real values. DO NOT commit .env.
# All services in this repo read from the same .env file.

# ===========================================================================
# WhatsApp pairing site (Node)
# ===========================================================================

PORT=3000

# Where to persist per-user WhatsApp auth state on disk.
# On Render, mount a Persistent Disk at this path so sessions survive restarts.
SESSIONS_DIR=./sessions

# Public base URL of the deployed site (not critical right now, but useful
# when wiring webhooks, share links, etc.)
PUBLIC_BASE_URL=http://localhost:3000

# Log level for Baileys / app logger: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ===========================================================================
# mysmsportal forwarders (shared by Telegram worker + WhatsApp worker)
# ===========================================================================

MYSMSPORTAL_USERNAME=your_portal_username
MYSMSPORTAL_PASSWORD=your_portal_password
POLL_INTERVAL_SECONDS=30
STARTUP_NOTIFY=true

# --- Telegram bot (bot.py) ---
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_CHAT_ID=123456789

# --- WhatsApp bot (whatsapp_bot.js) ---
# Digits-only phone number for `npm run pair`. Not needed at runtime.
WHATSAPP_PHONE_NUMBER=923001234567
# Optional: where to send alerts. Defaults to the linked account's own JID.
# Examples: 923001234567 (any number)  or  123456789-1234567890@g.us (group)
WHATSAPP_TARGET=
# Base64-encoded zip of auth_info_baileys/. Generate with `npm run export-auth`
# after pairing locally, then set this in Render env.
WHATSAPP_AUTH_BASE64=
