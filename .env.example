# Server
PORT=3000

# Where to persist per-user WhatsApp auth state on disk.
# On Render, mount a Persistent Disk at this path so sessions survive restarts.
SESSIONS_DIR=./sessions

# Public base URL of the deployed site (used for nothing critical right now,
# but useful when wiring webhooks, share links, etc.)
PUBLIC_BASE_URL=http://localhost:3000

# Log level for Baileys / app logger: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
